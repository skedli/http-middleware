{
    "name": "skedli/http-middleware",
    "description": "Provides PSR-15 middleware for HTTP requests, including correlation ID propagation, structured request/response logging, error handling, and stateless JWT authentication.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "jwt",
        "psr-7",
        "psr-15",
        "skedli",
        "middleware",
        "correlation-id",
        "http-middleware",
        "authentication",
        "x-correlation-id"
    ],
    "authors": [
        {
            "name": "Gustavo Freze de Araujo Santos",
            "homepage": "https://github.com/gustavofreze"
        }
    ],
    "homepage": "https://github.com/skedli/http-middleware",
    "support": {
        "issues": "https://github.com/skedli/http-middleware/issues",
        "source": "https://github.com/skedli/http-middleware"
    },
    "require": {
        "php": "^8.5",
        "ext-sodium": "*",
        "doctrine/dbal": "^4.4",
        "firebase/php-jwt": "^7.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "ramsey/uuid": "^4.9",
        "tiny-blocks/environment-variable": "^1.2",
        "tiny-blocks/http": "^4.9",
        "tiny-blocks/logger": "^1.3"
    },
    "require-dev": {
        "ext-openssl": "*",
        "ext-posix": "*",
        "ergebnis/composer-normalize": "^2.51",
        "guzzlehttp/psr7": "^2.9",
        "infection/infection": "^0.32",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Skedli\\HttpMiddleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\Skedli\\HttpMiddleware\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "fix-review": [
            "@phpcbf"
        ],
        "mutation-test": "php ./vendor/bin/infection --threads=max --logger-html=report/coverage/mutation-report.html --coverage=report/coverage",
        "phpcbf": "php ./vendor/bin/phpcbf --standard=phpcs.xml ./src",
        "phpcs": "php ./vendor/bin/phpcs --standard=phpcs.xml --extensions=php ./src",
        "phpstan": "php ./vendor/bin/phpstan analyse -c phpstan.neon.dist --quiet --no-progress",
        "review": [
            "@phpcs",
            "@phpstan"
        ],
        "test": "php -d memory_limit=2G ./vendor/bin/phpunit --configuration phpunit.xml tests",
        "test-file": "php ./vendor/bin/phpunit --configuration phpunit.xml --no-coverage --filter",
        "test-no-coverage": "php ./vendor/bin/phpunit --configuration phpunit.xml --no-coverage tests",
        "tests": [
            "@test",
            "@mutation-test"
        ],
        "tests-no-coverage": [
            "@test-no-coverage"
        ],
        "tests-no-mutation": [
            "@test"
        ]
    }
}
